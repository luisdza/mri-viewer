{
  "name": "mri-viewer-clone",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build && echo 'Push to main branch to deploy to GitHub Pages'",
    "lighthouse": "echo 'Lighthouse CLI conflicts with COOP/COEP headers. Use Chrome DevTools instead:' && echo '1. Run: npm run preview' && echo '2. Open http://localhost:4173/ in Chrome' && echo '3. Press F12 -> Lighthouse tab -> Analyze'",
    "lighthouse:devtools": "echo 'Opening DevTools instructions...' && start chrome://inspect"
  },
  "dependencies": {
    "@cornerstonejs/core": "^4.15.18",
    "@cornerstonejs/dicom-image-loader": "^1.86.0",
    "@cornerstonejs/tools": "^1.86.1",
    "dicom-parser": "^1.8.21",
    "lucide-react": "^0.303.0",
    "react": "^19.2.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.9",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "@babel/runtime": ">=7.26.10",
    "js-yaml": ">=3.14.2",
    "xmlbuilder2": {
      "js-yaml": ">=3.14.2"
    }
  }
}
